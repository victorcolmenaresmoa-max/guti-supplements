# =============================================================
# VARIABLES DE ENTORNO - ecommerce-suplementos
# Copia este archivo como ".env.local" en local, y en Vercel
# agrégalas en Project Settings -> Environment Variables.
# =============================================================

# URL del Web App publicado de Google Apps Script.
# Se obtiene tras hacer "Implementar" > "Nueva implementación" > "Aplicación web"
# Formato: https://script.google.com/macros/s/XXXXXXXXXXXXXXXXX/exec
NEXT_PUBLIC_GAS_URL=https://script.google.com/macros/s/TU_ID_DE_DESPLIEGUE/exec

# Contraseña simple para proteger el panel /admin (solo MVP, no es seguridad real).
# Debe coincidir con la que uses para entrar al dashboard.
NEXT_PUBLIC_ADMIN_PASSWORD=cambia-esta-clave

# Token secreto compartido entre el frontend y el Google Apps Script.
# Se envía en cada petición de escritura (crear/editar/borrar producto)
# para que el script rechace peticiones no autorizadas.
# Debe ser EXACTAMENTE el mismo valor que pongas en la constante
# ADMIN_TOKEN dentro de Codigo.gs
NEXT_PUBLIC_ADMIN_TOKEN=un-token-secreto-largo-y-dificil-de-adivinar
