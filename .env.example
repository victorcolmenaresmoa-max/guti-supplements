# URL pública /exec de la implementación de Google Apps Script.
NEXT_PUBLIC_GAS_URL=https://script.google.com/macros/s/TU_ID_DE_DESPLIEGUE/exec

# Contraseña para acceder al panel /admin.
NEXT_PUBLIC_ADMIN_PASSWORD=cambia-esta-clave

# Token compartido con ADMIN_TOKEN dentro de google-apps-script/Codigo.gs.
# Debe ser largo, difícil de adivinar y exactamente igual en ambos lugares.
NEXT_PUBLIC_ADMIN_TOKEN=un-token-secreto-largo-y-dificil-de-adivinar
